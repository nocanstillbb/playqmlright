{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--browser", "msedge"]
    },
    "qt-inspector": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--project",
        "/Users/hbb/source/repos/qml_mcp/mcp_server",
        "python",
        "/Users/hbb/source/repos/qml_mcp/mcp_server/server.py"
      ],
      "env": {
        "QML_INSPECTOR_SOCKET": "127.0.0.1:37521"
      }
    }
  }
}
