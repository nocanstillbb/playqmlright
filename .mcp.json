{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--browser", "msedge"]
    },
    "playqmlright": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--project",
        "playqmlright",
        "python",
        "playqmlright/server.py"
      ],
      "env": {
        "QML_INSPECTOR_SOCKET": "127.0.0.1:37521"
      }
    }
  }
}
